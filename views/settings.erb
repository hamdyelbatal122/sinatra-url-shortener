<h1>Account Settings</h1>

<% if @error %>
  <p style="color:#b42318;font-weight:600;"><%= @error %></p>
<% end %>
<% if @success %>
  <p style="color:#027a48;font-weight:600;"><%= @success %></p>
<% end %>

<div class="settings-section">
  <h2>Profile Information</h2>
  <p><strong>Username:</strong> <%= current_user.username || 'N/A' %></p>
  <p><strong>Email:</strong> <%= current_user.email || 'Not set' %></p>
  <p><strong>Role:</strong> <%= current_user.role %></p>
</div>

<% if current_user.password_hash %>
  <div class="settings-section">
    <h2>Change Password</h2>
    <form method="post" action="/settings/password">
      <input type="password" name="current_password" placeholder="Current password" required>
      <input type="password" name="new_password" placeholder="New password (min 8 chars)" required>
      <input type="password" name="confirm_password" placeholder="Confirm new password" required>
      <button type="submit">Update Password</button>
    </form>
  </div>
<% end %>

<div class="settings-section">
  <h2>Connected Accounts</h2>
  <p>Connect your social accounts for easier login:</p>
  <div class="oauth-connections">
    <% if current_user.oauth_connected?('google_oauth2') %>
      <div class="oauth-item connected">
        <span>✓ Google</span>
        <a href="/auth/disconnect/google_oauth2" class="btn-disconnect">Disconnect</a>
      </div>
    <% else %>
      <div class="oauth-item">
        <a href="/auth/google_oauth2" class="btn-connect google">Connect Google</a>
      </div>
    <% end %>

    <% if current_user.oauth_connected?('github') %>
      <div class="oauth-item connected">
        <span>✓ GitHub</span>
        <a href="/auth/disconnect/github" class="btn-disconnect">Disconnect</a>
      </div>
    <% else %>
      <div class="oauth-item">
        <a href="/auth/github" class="btn-connect github">Connect GitHub</a>
      </div>
    <% end %>
  </div>
</div>

<div class="settings-section">
  <h2>Email Notifications</h2>
  <form method="post" action="/settings/notifications">
    <label>
      <input type="checkbox" name="email_notifications_enabled" value="true"
        <%= current_user.email_notifications_enabled? ? 'checked' : '' %>>
      Enable email notifications for link events
    </label>
    <p style="font-size: 0.9em; color: #666;">
      You'll receive notifications when links are created or deleted.
    </p>
    <button type="submit">Save Preferences</button>
  </form>
</div>

<style>
  .settings-section {
    margin: 30px 0;
    padding: 20px;
    border: 1px solid #ddd;
    border-radius: 4px;
  }
  .oauth-connections {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 15px;
  }
  .oauth-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 4px;
  }
  .oauth-item.connected {
    background-color: #f0f9ff;
    border-color: #0284c7;
  }
  .btn-connect, .btn-disconnect {
    padding: 8px 16px;
    border-radius: 4px;
    text-decoration: none;
    font-weight: bold;
    cursor: pointer;
    border: none;
  }
  .btn-connect {
    background-color: #0284c7;
    color: white;
  }
  .btn-connect.google {
    background-color: #4285F4;
  }
  .btn-connect.github {
    background-color: #333;
  }
  .btn-disconnect {
    background-color: #dc2626;
    color: white;
  }
</style>
